# =============================================================================
# byggexp-api — production environment template
# =============================================================================
# Скопируй этот файл в /opt/byggexp-api/shared/.env на VPS,
# подставь реальные значения. НИКОГДА не коммить заполненный файл в git.
#
# После изменения файла на VPS обязательно:
#   pm2 restart byggexp-api --update-env
# =============================================================================

NODE_ENV=production

# Порт, который слушает NestJS. На VPS используем 3001
# (3010 занят opsplattform, 3000 свободен но зарезервирован)
PORT=3001

# -----------------------------------------------------------------------------
# MongoDB — Atlas (тот же кластер что opsplattform, разные БД)
# -----------------------------------------------------------------------------
# Формат: mongodb+srv://USER:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority
# База называется ByggExp
# Получить: MongoDB Atlas → Database → Connect → Drivers
# ⚠️ Atlas → Network Access должен разрешать IP VPS (185.189.51.128) или 0.0.0.0/0
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.zgjfrlf.mongodb.net/ByggExp?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# JWT — секрет для подписи токенов авторизации
# -----------------------------------------------------------------------------
# Генерация нового: openssl rand -base64 48
# ⚠️ При смене все пользователи разлогинятся
JWT_SECRET=замени_на_длинную_случайную_строку_минимум_32_символа
